    {
      "parameters": {},
      "id": "bf6a6e44-a0aa-4f82-8099-3f6490abca7c",
      "name": "Merge Ideas and Sheet",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        448,
        144
