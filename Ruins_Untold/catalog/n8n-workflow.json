    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:3333/generate",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ prompt: 'You are the lead researcher and content strategist for Ruins Untold, a long-form YouTube channel covering ancient mysteries, forbidden archaeology, and alternative history. Generate exactly 5 video ideas as a pure JSON array with no markdown fences, no preamble, and no explanation. Each idea must use this exact schema: {topic: short punchy title 5-10 words, angle: 3-5 sentences opening with mainstream consensus then cracking it with a physical anomaly naming the gatekeeper and ending on the unanswered question, key_evidence: minimum 4 specific items with paper titles dates artifacts locations documents years, key_researchers: named individuals with roles always including at least one antagonist labeled as such, related_video: prior Ruins Untold episode or none yet, hook_style: one of question statement contradiction anomaly revelation, tone_dial: integer 6-7 default never exceed 8}. Rules: every idea needs a concrete physical anomaly, a named gatekeeper institution, and specific dated sources. ' + ($('Config').first().json.topic ? 'All 5 ideas must focus specifically on: ' + $('Config').first().json.topic + '.' : 'Topics must span different eras, regions, and artifact types.') + ' Output ONLY the raw JSON array starting with [ and ending with ]. No other text.' }) }}",
        "options": {
          "timeout": 600000
        }
      },
      "id": "b4654799-394d-49b3-89ac-2b86ad9a17f4",
      "name": "Generate Ideas via Claude",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// Extract text from claude-bridge.py response\nconst responseText = items[0].json.output.trim();\n\n// Parse the JSON array — handle edge case where model wraps in backticks\nlet ideas;\ntry {\n  ideas = JSON.parse(responseText);\n} catch (e) {\n  const stripped = responseText.replace(/^```json?\\n?|```$/gm, '').trim();\n  try {\n    ideas = JSON.parse(stripped);\n  } catch (e2) {\n    const match = stripped.match(/(\\[\\s*\\{[\\s\\S]*\\}\\s*\\])/);\n    if (!match) throw new Error('Could not parse ideas. Raw: ' + responseText.slice(0, 300));\n    ideas = JSON.parse(match[1]);\n  }\n}\n\nif (!Array.isArray(ideas)) throw new Error('Expected JSON array, got: ' + typeof ideas);\n\n// Normalize a field value — handles string, array of strings, array of objects, or null\nfunction str(val) {\n  if (val === null || val === undefined) return '';\n  if (Array.isArray(val)) {\n    return val.map(item => {\n      if (item === null || item === undefined) return '';\n      if (typeof item === 'object') {\n        // Flatten object: join all values with \" — \"\n        return Object.values(item).filter(v => v !== null && v !== undefined).join(' — ');\n      }\n      return String(item);\n    }).filter(s => s.length > 0).join('; ');\n  }\n  if (typeof val === 'object') return Object.values(val).filter(v => v !== null && v !== undefined).join(' — ');\n  return String(val).trim();\n}\n\n// Tag each item as a new idea so Filter Duplicates can identify it\nreturn ideas.map(idea => ({\n  json: {\n    __type:          'new_idea',\n    topic:           str(idea.topic),\n    angle:           str(idea.angle),\n    key_evidence:    str(idea.key_evidence),\n    key_researchers: str(idea.key_researchers),\n    hook_style:      str(idea.hook_style),\n    tone_dial:       str(idea.tone_dial || 7),\n    related_video:   str(idea.related_video) || 'none yet'\n  }\n}));"
      },
