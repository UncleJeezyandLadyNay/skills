    },
    {
      "parameters": {
        "jsCode": "// Items are a mix of new ideas (tagged __type: 'new_idea') and existing sheet rows\nconst newIdeas     = items.filter(i => i.json.__type === 'new_idea');\nconst existingRows = items.filter(i => i.json.__type !== 'new_idea');\n\n// Build a set of existing topics — normalised to lowercase, collapsed whitespace\nconst existingTopics = new Set(\n  existingRows\n    .map(row => (row.json.TOPIC || '').toLowerCase().replace(/\\s+/g, ' ').trim())\n    .filter(t => t.length > 0)\n);\n\nconst uniqueIdeas = newIdeas.filter(idea => {\n  const topic = (idea.json.topic || '').toLowerCase().replace(/\\s+/g, ' ').trim();\n  return !existingTopics.has(topic);\n});\n\nreturn uniqueIdeas.length > 0 ? uniqueIdeas : [{ json: { __noNewIdeas: true } }];"
      },
